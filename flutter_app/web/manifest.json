{
  "manifest_version": 3,
  "name": "Allot — Control de Gastos",
  "short_name": "Allot",
  "version": "1.0.0",
  "description": "Control de gastos personales diarios con métricas y gráficas.",
  "icons": {
    "16":  "icons/Icon-192.png",
    "48":  "icons/Icon-192.png",
    "128": "icons/Icon-512.png"
  },
  "action": {
    "default_icon": {
      "16":  "icons/Icon-192.png",
      "48":  "icons/Icon-192.png",
      "128": "icons/Icon-512.png"
    },
    "default_title": "Allot"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["storage", "tabs"],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
